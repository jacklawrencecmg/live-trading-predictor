{
  "name": "Options Research",

  // GitHub's universal Codespace image — pre-installed with Python 3.x,
  // Node 20, and common tools. No features needed; just apt for Redis/Postgres.
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  "postCreateCommand": "bash .devcontainer/on-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",

  "forwardPorts": [3000, 8000],
  "portsAttributes": {
    "3000": {
      "label": "Frontend",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "8000": {
      "label": "Backend API",
      "onAutoForward": "silent",
      "visibility": "private"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
