{
  "name": "Options Research",

  // Python 3.11 base (Ubuntu 22.04 / Jammy). Node added via feature.
  // PostgreSQL and Redis are installed manually in on-create.sh to avoid
  // the postgres devcontainer feature which fails on many base images.
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },

  // Runs ONCE when the Codespace is first created.
  "postCreateCommand": "bash .devcontainer/on-create.sh",

  // Runs on every start/resume — starts Redis, postgres, backend, frontend.
  "postStartCommand": "bash .devcontainer/post-start.sh",

  "forwardPorts": [3000, 8000],
  "portsAttributes": {
    "3000": {
      "label": "Frontend",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "8000": {
      "label": "Backend API",
      "onAutoForward": "silent",
      "visibility": "private"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },

  "remoteUser": "vscode"
}
