# Backend-only env file for running outside Docker (local Python dev).
# Copy to backend/.env and adjust as needed.
#
#   cp .env.example .env
#   source .venv/bin/activate
#   uvicorn app.main:app --reload

ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/options_research
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=dev-secret-key-change-in-production
LOG_LEVEL=INFO
JSON_LOGS=false
